{
  "name": "rlab",
  "version": "0.2.0",
  "description": "rlab — a local web workspace for running coding agents (Claude, Codex, Gemini, OpenCode) with chat, git, browser preview, and worktrees.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Fariarx/rlab",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fariarx/rlab"
  },
  "bugs": {
    "url": "https://github.com/Fariarx/rlab/issues"
  },
  "private": false,
  "type": "module",
  "bin": {
    "rlab": "bin/rlab.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "index.html",
    "vite.config.ts",
    "vite-agents-plugin.ts",
    "tsconfig.json",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "cross-env NODE_ENV=production vite preview --host 0.0.0.0",
    "serve": "cross-env NODE_ENV=production vite preview --host 0.0.0.0",
    "start": "node bin/rlab.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:e2e": "playwright test",
    "smoke:agents": "node scripts/agent-smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.167",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@vitejs/plugin-react": "^6.0.2",
    "mobx": "^6.16.0",
    "mobx-react-lite": "^4.1.1",
    "playwright": "^1.60.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.22.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "protobufjs": "7.5.8"
  }
}
